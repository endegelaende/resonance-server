# =============================================================================
# Resonance Music Server — Environment Variables
# =============================================================================
# Copy this file to .env and adjust the values to match your setup.
#
#   cp .env.example .env
#
# All variables have sensible defaults and are optional.
# =============================================================================

# --- Music Library ---
# Path on the host to your music collection (mounted read-only into the container)
MUSIC_DIR=/mnt/music

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Display Rendering ---
# Enable bitmap display rendering for Squeezebox 2/3/Classic/Boom/Transporter.
# Set to 1 once you have verified your hardware works correctly.
RESONANCE_DISPLAY=0

# --- Timezone ---
# Container timezone (affects log timestamps, scheduled tasks, etc.)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=UTC
